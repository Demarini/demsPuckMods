# Build artifacts (every C# project)
**/bin/
**/obj/

# Visual Studio per-folder state
**/.vs/
.vs/

# Visual Studio upgrade logs (one-off migration artifacts)
UpgradeLog*.htm

# Asset bundles are Unity-built binaries — they ship via Workshop, not git.
# Track only the hand-edited AssetInformation.json sidecars.
demsPuckMods/SceneryChanger/AssetBundles/*
!demsPuckMods/SceneryChanger/AssetBundles/AssetInformation.json

demsPuckMods/SceneryMaps/*/AssetBundles/*
!demsPuckMods/SceneryMaps/*/AssetBundles/AssetInformation.json
